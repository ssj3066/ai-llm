SGLANG_MODEL_PATH=Qwen/Qwen3-4B-Instruct-2507
SGLANG_HOST=127.0.0.1
SGLANG_PORT=30000
SGLANG_CONTEXT_LENGTH=32768
SGLANG_MEM_FRACTION_STATIC=0.82
SGLANG_ATTENTION_BACKEND=torch_native
SGLANG_SAMPLING_BACKEND=pytorch
SGLANG_KV_CACHE_DTYPE=fp8_e5m2
SGLANG_ENABLE_CACHE_REPORT=true
# SGLANG_QUANTIZATION is only for a matching quantized checkpoint, for example AWQ/GPTQ/FP8.
SGLANG_QUANTIZATION=
SGLANG_EXTRA_ARGS=--disable-cuda-graph --disable-overlap-schedule
